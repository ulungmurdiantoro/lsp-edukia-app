APP_NAME="LSP Edukia"
APP_ENV=production
APP_KEY=                          # Isi dengan: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://blanchedalmond-cod-695957.hostingersite.com   # Ganti dengan domain Anda

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=single
LOG_LEVEL=error

# ─── DATABASE ────────────────────────────────────────────────────────────────
# Pilih salah satu: MySQL (direkomendasikan untuk production) atau SQLite

# Opsi 1: MySQL (buat database di hPanel → Databases)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=u297990197_lsp_edukia
DB_USERNAME=u297990197_lsp_edukia
DB_PASSWORD=cYijga;5|K

# Opsi 2: SQLite (lebih mudah, file harus ada dan writable)
# DB_CONNECTION=sqlite
# DB_DATABASE=/home/user/nama-domain.com/database/database.sqlite

# ─── SESSION, CACHE, QUEUE ───────────────────────────────────────────────────
# Gunakan 'file' untuk shared hosting — tidak butuh tabel database tambahan
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file

# Sync = langsung dijalankan tanpa queue worker (cocok untuk shared hosting)
QUEUE_CONNECTION=sync

# ─── FILESYSTEM ──────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ─── MAIL (opsional) ─────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="LSP Edukia"

# ─── SEO / PENGUKURAN (Fase 1 blueprint) ─────────────────────────────────────
# Paksa HTTPS untuk canonical/OG/sitemap (otomatis aktif saat APP_ENV=production)
APP_FORCE_HTTPS=true

# Google Analytics 4 — Measurement ID dari GA4 (kosongkan jika belum ada)
GOOGLE_ANALYTICS_ID=

# Token verifikasi kepemilikan situs (ambil dari dashboard masing-masing)
GOOGLE_SITE_VERIFICATION=     # Google Search Console (metode "HTML tag")
BING_SITE_VERIFICATION=       # Bing Webmaster Tools

# Profil sosial resmi untuk schema Organization sameAs — pisahkan dengan koma
# Contoh: SOCIAL_PROFILES=https://instagram.com/lspedukia,https://facebook.com/lspedukia
SOCIAL_PROFILES=

# Dashboard GA4 di admin Filament — Property ID GA4 (GA4 → Admin → Property Settings).
# Wajib juga unggah kredensial service account ke: storage/app/analytics/service-account-credentials.json
ANALYTICS_PROPERTY_ID=

# Kontak (opsional — default sudah di config/site.php)
# SITE_PHONE=+6285175479385
# SITE_WHATSAPP=6285175479385
# SITE_EMAIL=edukasi.cendekia@gmail.com
